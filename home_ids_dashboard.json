{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "Script Memory Footprint (Slots)",
      "gridPos": { "x": 0, "y": 0, "w": 5, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"home_ids\"} / 1024 / 1024",
          "legendFormat": "RSS Memory (MB)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "megabytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "stat",
      "title": "Anti-Poisoning Freezes",
      "gridPos": { "x": 5, "y": 0, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "count(home_ids_risk_score >= 7.0) or vector(0)",
          "legendFormat": "Frozen Pipelines",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "timeseries",
      "title": "Alert Pipeline Velocity & Backlog",
      "gridPos": { "x": 9, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "home_ids_alert_queue_size",
          "legendFormat": "Queue Backlog",
          "refId": "A"
        },
        {
          "expr": "rate(home_ids_alerts_total[5m]) * 60",
          "legendFormat": "Dispatched Alerts/min",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "SQLite WAL Velocity vs Lag",
      "gridPos": { "x": 15, "y": 0, "w": 5, "h": 6 },
      "targets": [
        {
          "expr": "home_ids_collector_lag_seconds",
          "legendFormat": "Read Lag (s)",
          "refId": "A"
        },
        {
          "expr": "rate(home_ids_events_processed_total[5m])",
          "legendFormat": "Ingestion (eps)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "stat",
      "title": "Live Baseline Breaches",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "count(home_ids_query_rate > home_ids_query_rate_threshold_limit) or vector(0)",
          "legendFormat": "Breached Limits",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "timeseries",
      "title": "Threat Thresholds vs Safe Baseline Corridor (Query Rate)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "home_ids_query_rate{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} - Live Traffic",
          "refId": "A"
        },
        {
          "expr": "home_ids_query_rate_baseline_mean{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} - Baseline Mean",
          "refId": "B"
        },
        {
          "expr": "home_ids_query_rate_threshold_limit{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} - Threat Limit",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*Baseline Mean.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*Threat Limit.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [5, 5] } },
              { "id": "custom.fillBelowTo", "value": ".*Baseline Mean.*" },
              { "id": "custom.fillOpacity", "value": 15 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Baseline Deviations (Z-Scores) — Behavioral Threats",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "home_ids_zscore_query_rate{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} Query-Z",
          "refId": "A"
        },
        {
          "expr": "home_ids_zscore_nxdomain_ratio{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} NXDOMAIN-Z",
          "refId": "B"
        },
        {
          "expr": "home_ids_zscore_blocked_ratio{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} Blocked-Z",
          "refId": "C"
        },
        {
          "expr": "home_ids_zscore_suspicious_domains{hostname=~\"$device\"}",
          "legendFormat": "{{hostname}} DGA-Z",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 3, "color": "yellow" },
              { "value": 5, "color": "orange" },
              { "value": 8, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "table",
      "title": "All Devices — Baseline & Threat Ledger",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "home_ids_risk_score{hostname=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "home_ids_query_rate{hostname=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "home_ids_ml_anomaly_score{hostname=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "home_ids_ti_risk{hostname=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "home_ids_zeek_ja3_malicious{hostname=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "hostname", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "device": true },
            "renameByName": {
              "Value #A": "Live Risk",
              "Value #B": "Queries/min",
              "Value #C": "ML Score",
              "Value #D": "TI Threat",
              "Value #E": "JA3 Hash",
              "device_type": "Type",
              "hostname": "Hostname"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [ { "desc": true, "displayName": "Live Risk" } ] }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hostname" },
            "properties": [ { "id": "custom.align", "value": "left" } ]
          },
          {
            "matcher": { "id": "byName", "options": "Live Risk" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "green" },
                    { "value": 3, "color": "yellow" },
                    { "value": 6, "color": "red" }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "TI Threat" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "green" },
                    { "value": 0.5, "color": "red" }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "JA3 Hash" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "green" },
                    { "value": 0.5, "color": "red" }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [ "home-ids", "health", "triage" ],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": [ "All" ], "value": [ "$__all" ] },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "hide": 0,
        "includeAll": true,
        "label": "Target Host",
        "multi": true,
        "name": "device",
        "options": [],
        "query": "label_values(home_ids_risk_score, hostname)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Home IDS — Health & Threat Triage",
  "uid": "home-ids-health-triage-v1",
  "version": 1
}