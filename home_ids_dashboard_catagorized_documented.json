          "links": [{
            "title": "🔍 Audit Candidate Algorithmic Strings",
            "url": "/explore?orgId=1&left=%5B%22now-1h%22,%22now%22,%22Loki%22,%7B%22expr%22:%22%7Bfilename%3D~%22.*_stream.jsonl%22%7D%20%7C%20json%20%7C%20hostname%3D~%22$device%22%20%7C~%22(?i)suspicious%2Fdga%22%22%7D%5D",
