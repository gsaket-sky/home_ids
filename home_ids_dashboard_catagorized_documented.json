  "uid": "home-ids-master-v2",
  "version": 1,
  "panels": [
    {
      "id": 1000,
      "type": "row",
      "title": "🔴 System & Script Health",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}
    },
    {
      "id": 10001,
      "type": "text",
      "title": "",
      "gridPos": {"x": 0, "y": 1, "w": 24, "h": 3},
      "options": {
        "mode": "markdown",
        "content": "**How to read this section:** Monitors the physical health of your Python engine, SQLite database, and Zeek collectors.\n* 🟢 **Normal:** Collector lag < 2 seconds. Zeek Status is 1. The Script Memory Footprint is a flat, horizontal line. Alert Queue stays at 0.\n* 🔴 **Abnormal / Threat:** A diagonal memory line indicates a leak. Lag > 15s means the Pi-hole database is locked. Anti-Poisoning Freezes > 0 means the script detected a Day-Zero threat and intentionally locked its own learning memory to prevent baseline poisoning."
      },
      "transparent": true
    },
    {"id":1,"type":"stat","title":"ML Model Status","gridPos":{"x":0,"y":4,"w":2,"h":4},"targets":[{"expr":"home_ids_ml_model_loaded","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":11,"type":"stat","title":"Zeek Status","gridPos":{"x":2,"y":4,"w":2,"h":4},"targets":[{"expr":"home_ids_zeek_status","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":2,"type":"stat","title":"Collector Lag","gridPos":{"x":4,"y":4,"w":2,"h":4},"targets":[{"expr":"home_ids_collector_lag_seconds","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":3,"type":"stat","title":"Alert Queue Size","gridPos":{"x":6,"y":4,"w":3,"h":4},"targets":[{"expr":"home_ids_alert_queue_size","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":4,"type":"stat","title":"Alerts Fired (last 1h)","gridPos":{"x":9,"y":4,"w":3,"h":4},"targets":[{"expr":"increase(home_ids_alerts_total[1h])","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":5,"type":"stat","title":"DNS / min","gridPos":{"x":12,"y":4,"w":2,"h":4},"targets":[{"expr":"rate(home_ids_events_processed_total[10m]) * 60","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":13,"type":"stat","title":"Zeek / min","gridPos":{"x":14,"y":4,"w":2,"h":4},"targets":[{"expr":"rate(home_ids_zeek_events_processed_total[10m]) * 60","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":502,"type":"stat","title":"Anti-Poisoning Freezes","gridPos":{"x":16,"y":4,"w":3,"h":4},"targets":[{"expr":"count(home_ids_risk_score >= 7.0) or vector(0)","refId":"A"}],"options":{"colorMode":"background"}},
    {"id":8,"type":"timeseries","title":"Collector Lag Trend","gridPos":{"x":19,"y":4,"w":5,"h":4},"targets":[{"expr":"home_ids_collector_lag_seconds","refId":"A"}],"fieldConfig":{"defaults":{"custom":{"fillOpacity":10, "lineWidth":1}}}},
    {"id":501,"type":"timeseries","title":"Script Memory Footprint (Slots)","gridPos":{"x":0,"y":8,"w":8,"h":5},"targets":[{"expr":"process_resident_memory_bytes{job=\"home_ids\"} / 1024 / 1024","legendFormat":"RSS (MB)","refId":"A"}],"fieldConfig":{"defaults":{"unit":"megabytes","custom":{"fillOpacity":10,"lineWidth":2}}}},
    {"id":503,"type":"timeseries","title":"Alert Pipeline Backlog","gridPos":{"x":8,"y":8,"w":8,"h":5},"targets":[{"expr":"home_ids_alert_queue_size","legendFormat":"Queue","refId":"A"},{"expr":"rate(home_ids_alerts_total[5m])*60","legendFormat":"Alerts/min","refId":"B"}],"fieldConfig":{"defaults":{"custom":{"fillOpacity":5,"lineWidth":2}}}},
    {"id":504,"type":"timeseries","title":"SQLite WAL Velocity vs Lag","gridPos":{"x":16,"y":8,"w":8,"h":5},"targets":[{"expr":"home_ids_collector_lag_seconds","legendFormat":"Lag (s)","refId":"A"},{"expr":"rate(home_ids_events_processed_total[5m])","legendFormat":"Ingest/s","refId":"B"}],"fieldConfig":{"defaults":{"custom":{"lineWidth":2}}}},

    {
      "id": 2000,
      "type": "row",
      "title": "🌐 Overall Network View",
      "gridPos": {"x": 0, "y": 13, "w": 24, "h": 1}
    },
    {
      "id": 20001,
      "type": "text",
      "title": "",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 3},
      "options": {
        "mode": "markdown",
        "content": "**How to read this section:** Your 30,000-foot daily driver. It provides a macro view of every device and immediately highlights rule-breakers.\n* 🟢 **Normal:** The 'Severe Threats' counter is 0. On the corridor chart, the solid live traffic lines stay comfortably beneath the dotted 'Threat Limit' ceiling.\n* 🔴 **Abnormal / Threat:** Solid traffic lines breaking violently through the top of the dotted Threat Limit line. Any device glowing red (Score > 6.0) in the Threat Ledger requires immediate investigation below."
      },
      "transparent": true
    },
    {"id":6,"type":"stat","title":"Active Devices","gridPos":{"x":0,"y":17,"w":3,"h":4},"targets":[{"expr":"count(home_ids_risk_score) or vector(0)","refId":"A"}],"options":{"colorMode":"background"}},
    {
      "id": 7,
      "type": "stat",
      "title": "Severe Threats (Risk ≥ 6.0)",
      "gridPos": {"x": 3, "y": 17, "w": 3, "h": 4},
      "targets": [{"expr": "count(home_ids_risk_score >= 6.0) or vector(0)", "refId": "A"}],
      "options": {"colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "red"}]
          }
        }
      }
    },
    {"id":12,"type":"stat","title":"Live Baseline Breaches","gridPos":{"x":6,"y":17,"w":4,"h":4},"targets":[{"expr":"count(home_ids_query_rate > home_ids_query_rate_threshold_limit) or vector(0)","refId":"A"}],"options":{"colorMode":"background"},"fieldConfig":{"defaults":{"thresholds":{"mode":"absolute","steps":[{"value":0,"color":"green"},{"value":1,"color":"red"}]}}}},
    {"id":90,"type":"stat","title":"Engine Max Risk","gridPos":{"x":10,"y":17,"w":4,"h":4},"targets":[{"expr":"max(home_ids_risk_score{hostname=~\"$device\"})","refId":"A"}]},
    {"id":92,"type":"timeseries","title":"Pipeline EPS","gridPos":{"x":14,"y":17,"w":5,"h":4},"targets":[{"expr":"rate(home_ids_events_processed_total[10m]) * 60","refId":"A"}]},
    {"id":93,"type":"timeseries","title":"Pipeline Alerts","gridPos":{"x":19,"y":17,"w":5,"h":4},"targets":[{"expr":"rate(home_ids_alerts_total[10m]) * 300","refId":"A"}]},
    {"id":10,"type":"timeseries","title":"Risk Score Timeline — All Devices","gridPos":{"x":0,"y":21,"w":12,"h":8},"targets":[{"expr":"home_ids_risk_score{hostname=~\"$device\"}","legendFormat":"{{hostname}}","refId":"A"}],"fieldConfig":{"defaults":{"custom":{"fillOpacity":10,"lineWidth":1},"thresholds":{"mode":"absolute","steps":[{"value":0,"color":"green"},{"value":3,"color":"yellow"},{"value":6,"color":"red"}]}}}},
    {"id":20,"type":"timeseries","title":"Threat Thresholds vs Safe Baseline Corridor (Query Rate)","gridPos":{"x":12,"y":21,"w":12,"h":8},"targets":[{"expr":"home_ids_query_rate{hostname=~\"$device\"}","legendFormat":"{{hostname}} - Live","refId":"A"},{"expr":"home_ids_query_rate_baseline_mean{hostname=~\"$device\"}","legendFormat":"{{hostname}} - Mean","refId":"B"},{"expr":"home_ids_query_rate_threshold_limit{hostname=~\"$device\"}","legendFormat":"{{hostname}} - Limit","refId":"C"}],"fieldConfig":{"defaults":{"custom":{"lineWidth":2,"fillOpacity":0}},"overrides":[{"matcher":{"id":"byRegexp","options":".*Mean.*"},"properties":[{"id":"custom.lineStyle","value":{"fill":"dash","dash":[10,10]}},{"id":"custom.lineWidth","value":1}]},{"matcher":{"id":"byRegexp","options":".*Limit.*"},"properties":[{"id":"custom.lineStyle","value":{"fill":"dash","dash":[5,5]}},{"id":"custom.fillBelowTo","value":".*Mean.*"},{"id":"custom.fillOpacity","value":15},{"id":"color","value":{"mode":"fixed","fixedColor":"red"}}]}]}},
    {
      "id": 80,
      "type": "table",
      "title": "All Devices — Baseline & Threat Ledger",
      "gridPos": {"x": 0, "y": 29, "w": 24, "h": 10},
      "targets": [
        {"expr": "home_ids_risk_score{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "A"},
        {"expr": "home_ids_query_rate{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "B"},
        {"expr": "home_ids_ml_anomaly_score{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "C"},
        {"expr": "home_ids_ti_risk{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "D"},
        {"expr": "home_ids_zeek_ja3_malicious{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "E"},
        {"expr": "home_ids_unique_domains{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "F"},
        {"expr": "home_ids_blocked_ratio{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "G"},
        {"expr": "home_ids_ti_match{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "H"},
        {"expr": "home_ids_zeek_conn_count{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "I"},
        {"expr": "home_ids_zeek_new_ips{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "J"},
        {"expr": "home_ids_zeek_notices{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "K"},
        {"expr": "home_ids_safe_device{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "L"},
        {"expr": "home_ids_probation_status{hostname=~\"$device\"}", "format": "table", "instant": true, "refId": "M"}
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "hostname", "mode": "outer"}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true, "Time 7": true, "Time 8": true, "Time 9": true, "Time 10": true, "Time 11": true, "Time 12": true, "__name__": true, "device": true},
            "renameByName": {
              "Value #A": "Live Risk", "Value #B": "Queries/min", "Value #C": "ML Score", "Value #D": "TI Threat", "Value #E": "JA3 Hash",
              "Value #F": "Unique Domains", "Value #G": "Blocked Ratio", "Value #H": "TI Match Flag", "Value #I": "Zeek Conns",
              "Value #J": "Zeek New IPs", "Value #K": "Zeek Notices", "Value #L": "Safe-Listed", "Value #M": "Probation", "device_type": "Type", "hostname": "Hostname"
            }
          }
        },
        {"id": "sortBy", "options": {"fields": [{"desc": true, "displayName": "Live Risk"}]}}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "center"},
          "links": [
            {
              "title": "🔍 Deep-Dive Logs for ${__data.fields.Hostname}",
              "url": "/explore?orgId=1&left=%5B%22now-1h%22,%22now%22,%22Loki%22,%7B%22expr%22:%22%7Bfilename%3D~%22.*_stream.jsonl%22%7D%20%7C%20json%20%7C%20hostname%3D~%22${__data.fields.Hostname}%22%22%7D%5D",
              "targetBlank": true
            }
          ]
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Hostname"}, "properties": [{"id": "custom.align", "value": "left"}]},
          {"matcher": {"id": "byName", "options": "Live Risk"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 3, "color": "yellow"}, {"value": 6, "color": "red"}]}}]},
          {"matcher": {"id": "byName", "options": "TI Threat"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "red"}]}}]},
          {"matcher": {"id": "byName", "options": "JA3 Hash"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "red"}]}}]},
          {"matcher": {"id": "byName", "options": "Safe-Listed"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": 0, "color": "grey"}, {"value": 1, "color": "blue"}]}}]},
          {"matcher": {"id": "byName", "options": "Probation"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "orange"}]}}]}
        ]
      }
    },

