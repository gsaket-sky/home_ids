      "title": "NXDOMAIN Ratio (DGA Indicator)",
      "gridPos": {"x": 16, "y": 85, "w": 8, "h": 8},
      "targets": [{"expr": "home_ids_nxdomain_ratio{hostname=~\"$device\"}", "legendFormat": "{{hostname}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.3, "color": "yellow"}, {"value": 0.5, "color": "red"}]},
          "links": [{
            "title": "🔍 Investigate Missing Routing Lookups",
            "url": "/explore?orgId=1&left=%5B%22now-1h%22,%22now%22,%22Loki%22,%7B%22expr%22:%22%7Bfilename%3D~%22.*_stream.jsonl%22%7D%20%7C%20json%20%7C%20hostname%3D~%22$device%22%20%7C~%22(?i)nxdomain%22%22%7D%5D",
